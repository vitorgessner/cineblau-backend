// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator user {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  lastName  String
  cpf       String   @unique
  dtOfBirth DateTime
  sex       String
  email     String   @unique
  phone     String   @unique
  isAdmin   Boolean
  password String
  address   Address?
  tickets Ticket[]
}

model Address {
  id           Int     @id @default(autoincrement())
  state        String
  city         String
  neighborhood String
  street       String
  number       Int
  complement   String?
  cep          String
  user       User?  @relation(fields: [userId], references: [id])
  userId     Int     @unique
  room Room? @relation(fields: [roomId], references: [id])
  roomId Int @unique
}

model Film {
  id Int @id @default(autoincrement())
  title String
  synopsis String
  premiere DateTime
  rating Float
  duration Int
  posterPath String
  awards AwardsOnFilms[]
  directors DirectorsOnFilms[]
  cast ActorsOnFilms[]
  genres GenresOnFilms[]
  sessions Session[]
}

model Award {
  id Int @id @default(autoincrement())
  name String
  date DateTime
  category String
  film AwardsOnFilms[]
}

model AwardsOnFilms {
  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId Int
  award Award @relation(fields: [awardId], references: [id], onDelete: Cascade)
  awardId Int
  @@id([filmId, awardId])
}

model Director {
  id Int @id @default(autoincrement())
  name String
  films DirectorsOnFilms[]
}

model DirectorsOnFilms {
  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId Int
  director Director @relation(fields: [directorId], references: [id], onDelete: Cascade)
  directorId Int
  @@id([filmId, directorId])
}

model Actor {
  id Int @id @default(autoincrement())
  name String
  films ActorsOnFilms[]
}

model ActorsOnFilms {
  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId Int
  actor Actor @relation(fields: [actorId], references: [id], onDelete: Cascade)
  actorId Int
  @@id([filmId, actorId])
}

model Genre {
  id Int @id @default(autoincrement())
  name String
  films GenresOnFilms[]
}

model GenresOnFilms {
  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId Int
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)
  genreId Int
  @@id([filmId, genreId])
}

model RoomType {
  id Int @id @default(autoincrement())
  type String
  description String
  capacity Int
  basePrice Float
  room Room[]
}

model Room {
  id Int @id @default(autoincrement())
  number Int
  roomType RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Restrict)
  roomTypeId Int
  address Address?
  sessions Session[]
  sessionId Int @unique
}

model Session {
  id Int @id @default(autoincrement())
  date DateTime
  language String
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId Int
  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade)
  filmId Int
  seats Seat[]
}

model Seat {
  id Int @id @default(autoincrement())
  acronym String
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId Int
  seats Ticket[]
}

model Ticket {
  id Int @id @default(autoincrement())
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId Int
  seat Seat @relation(fields: [seatId], references: [id], onDelete: Restrict)
  seatId Int
  date DateTime
  discount Discount @relation(fields: [discountId], references: [id], onDelete: Restrict)
  discountId Int
}

model Discount {
  id Int @id @default(autoincrement())
  type String
  multiplier Float
  tickets Ticket[]
}